{
  "name": "@ghost-shard/sdk",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./identity": {
      "import": "./dist/identity/index.js",
      "require": "./dist/identity/index.cjs",
      "types": "./dist/identity/index.d.ts"
    },
    "./utils": {
      "import": "./dist/utils/index.js",
      "require": "./dist/utils/index.cjs",
      "types": "./dist/utils/index.d.ts"
    },
    "./rpc": {
      "import": "./dist/rpc/index.js",
      "require": "./dist/rpc/index.cjs",
      "types": "./dist/rpc/index.d.ts"
    }
  },
  "scripts": {
    "vercel-build": "npm run build && cd examples/ghost-frontend && next build",
    "build": "tsup src/index.ts src/identity/index.ts src/utils/index.ts src/rpc/index.ts --format esm,cjs --dts --clean --splitting --treeshake --external @noble/curves --external @noble/hashes --external @noble/secp256k1 --external viem --external wagmi --external @tanstack/react-query",
    "clean": "Remove-Item -Recurse -Force dist",
    "test": "vitest"
  },
  "dependencies": {
    "@noble/curves": "^1.8.1",
    "@noble/hashes": "^1.7.1",
    "@scure/base": "^1.2.4",
    "@zerodev/sdk": "^5.5.10",
    "dotenv": "^17.4.2",
    "lucide-react": "^1.17.0",
    "next": "^16.2.7"
  },
  "peerDependencies": {
    "@tanstack/react-query": "^5.0.0",
    "react": "^19.0.0",
    "viem": "^2.0.0",
    "wagmi": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.0",
    "tsup": "^8.5.1",
    "typescript": "^5.7.0",
    "vitest": "^4.1.7",
    "prettier": "^3.8.3"
  },
  "pnpm": {
    "overrides": {
      "node-domexception": "npm:empty-package@1.0.0"
    }
  }
}