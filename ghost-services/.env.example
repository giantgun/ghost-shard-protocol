# GhostRouter address (deployed)
ROUTER_ADDRESS=0x907A275A34236B7a15c6C7d8826353fEdBf4c6ed

# Paymaster EOA private key (for signing paymaster approvals)
PAYMASTER_PRIVATE_KEY=0x...

# Relayer EOA private key (for submitting transactions)
RELAYER_PRIVATE_KEY=0x...

# Comma-separated list of user (shard owner) addresses the paymaster is willing to sponsor
ALLOWED_USERS=0x...,0x...

# Public RPC for reads + eth_call simulation
READ_RPC_URL=https://ethereum-mainnet.g.alchemy.com/v2/...

# Private RPC for transaction submission (Flashbots / MEV-Share)
PRIVATE_RPC_URL=https://rpc.flashbots.net

# Unified service port (formerly separate PAYMASTER_PORT=3001 and BUNDLER_PORT=3002)
PORT=3000
